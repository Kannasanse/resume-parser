{
  "manifest_version": 3,
  "name": "Proflect — Screen Recorder & Transcript",
  "version": "1.0.0",
  "description": "Transcribe any video playing in your browser with one click.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://proflect-neo.vercel.app/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
